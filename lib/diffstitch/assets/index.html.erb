<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/diff2html/bundles/css/diff2html.min.css">
  <link rel="stylesheet" href="styles.css">
</head>
<body class="d-flex flex-column vh-100 overflow-hidden">
  <header class="topnav d-flex align-items-center gap-3 px-3 py-2 flex-shrink-0">
    <h1 class="fs-6 fw-semibold font-monospace text-truncate flex-fill mb-0" id="page-title"></h1>
    <div class="d-flex align-items-center gap-2 flex-shrink-0">
      <label for="branch-select" class="mb-0 small fw-semibold text-uppercase" style="color:#8b949e;letter-spacing:.06em">Branch</label>
      <select id="branch-select" class="branch-select form-select form-select-sm font-monospace" style="width:auto"></select>
    </div>
  </header>

  <div class="d-flex flex-fill overflow-hidden">
    <div class="d-flex flex-column flex-fill overflow-hidden panel-left">
      <div class="d-flex align-items-center gap-2 panel-header">
        <span class="font-monospace fw-semibold" id="base-label"></span>
        <span class="ds-badge">base</span>
      </div>
      <div class="flex-fill overflow-auto panel-content" id="left-content"></div>
    </div>
    <div class="d-flex flex-column flex-fill overflow-hidden">
      <div class="d-flex align-items-center gap-2 panel-header">
        <span class="font-monospace fw-semibold" id="branch-label"></span>
        <span class="ds-badge">changes</span>
      </div>
      <div class="flex-fill overflow-auto panel-content" id="right-content"></div>
    </div>
  </div>

  <div id="diff-staging" class="d-none position-absolute invisible pe-none"></div>

  <script src="https://cdn.jsdelivr.net/npm/diff2html/bundles/js/diff2html.min.js"></script>
  <script src="data.js"></script>
  <script src="app.js"></script>
</body>
</html>
